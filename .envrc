# Required for the Antigravity provider (Google Cloud Code API).
# ANTIGRAVITY_OAUTH_CLIENT_ID=your-client-id
# ANTIGRAVITY_OAUTH_CLIENT_SECRET=your-client-secret

# Required only when using the Ollama provider.
# OLLAMA_SESSION_COOKIE=

# Secret token for the OTLP sink server (required for 'usage-limits serve')
# OPENROUTER_SINK_TOKEN=
